<Page x:Class="CamaraPortuaria.UI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:CamaraPortuaria.UI.Controls"
      Title="Inicio">
    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <TextBlock Text="Inicio" Style="{StaticResource PageTitle}" />

            <!-- Resumen rápido -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResumenRecibosVencidos}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                        <TextBlock Text="Recibos vencidos" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="8,0,0,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResumenRecibosPendientes}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Recibos pendientes de pago" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Accesos rápidos -->
            <TextBlock Text="Accesos rápidos" FontWeight="SemiBold" FontSize="14"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <UniformGrid Columns="3">

                <Button Command="{Binding IrARecibosCommand}" Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButton}" Height="72" Width="Auto" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ReceiptMoney24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Recibos" FontWeight="SemiBold" />
                            <TextBlock Text="Listado de recibos emitidos" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAEmisionMasivaCommand}" Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButton}" Height="72" Width="Auto" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DocumentMultiple24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Emisión masiva" FontWeight="SemiBold" />
                            <TextBlock Text="Emitir recibos por grupo" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAControlPagosCommand}" Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButton}" Height="72" Width="Auto" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="MoneyHand24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Control" FontWeight="SemiBold" />
                            <TextBlock Text="Buscar y gestionar recibos" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>

        <controls:BusyOverlay />
    </Grid>
</Page>
