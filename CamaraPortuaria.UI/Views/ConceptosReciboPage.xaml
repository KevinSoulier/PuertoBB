<Page x:Class="CamaraPortuaria.UI.Views.ConceptosReciboPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Detalles de recibo">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Detalles de recibo" Style="{StaticResource PageTitle}" />

        <ui:TextBox Grid.Row="2" Margin="0,0,0,12"
                 Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Buscar detalle…"
                 IsEnabled="{Binding NoEnEdicion}" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding ConceptosFiltrados}" SelectedItem="{Binding Seleccionado}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False" Margin="0,0,16,0"
                      SelectionMode="Single" IsEnabled="{Binding NoEnEdicion}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Detalle" Binding="{Binding Nombre}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Padding="16" CornerRadius="8"
                    Background="{DynamicResource LayerFillColorDefaultBrush}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Ficha de detalle" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel IsEnabled="{Binding EnEdicion}">
                        <TextBlock Text="Detalle" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NombreEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    </StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:Button Content="Nuevo" Command="{Binding NuevoCommand}"
                                       Style="{StaticResource AccionIconButton}"
                                       ToolTip="Crear un nuevo concepto de recibo">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Editar" Command="{Binding EditarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Editar el concepto seleccionado">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Eliminar el concepto seleccionado">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Aceptar" Command="{Binding AceptarCommand}"
                                       Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                       ToolTip="Guardar los cambios del concepto">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Cancelar la edición">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
