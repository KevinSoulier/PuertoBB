<Page x:Class="CamaraPortuaria.UI.Views.GruposPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Grupos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Grupos de facturación" Style="{StaticResource PageTitle}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Grupos}" SelectedItem="{Binding Seleccionado}"
                     DisplayMemberPath="Nombre" Margin="0,0,16,0"
                     IsEnabled="{Binding NoEnEdicion}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling" />

            <Border Grid.Column="1" Padding="16" CornerRadius="8"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Datos del grupo" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <StackPanel Grid.Row="1" IsEnabled="{Binding EnEdicion}">
                        <TextBlock Text="Nombre" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NombreEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Descripción" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DescripcionEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Ítems a facturar -->
                    <Border Grid.Row="2" Padding="12" CornerRadius="6" Margin="0,0,0,8"
                            IsEnabled="{Binding EnEdicion}"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding TotalEditTexto, StringFormat='Total: {0}'}"
                                           DockPanel.Dock="Right" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="Ítems a facturar"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding LineasEdit}"
                                      AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal" MaxHeight="160"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Descripción"  Binding="{Binding Descripcion}"     Width="*"   />
                                    <DataGridTextColumn Header="Cant."        Binding="{Binding CantidadTexto}"   Width="60"  />
                                    <DataGridTextColumn Header="Precio unit." Binding="{Binding PrecioUnitTexto}" Width="110" />
                                    <DataGridTextColumn Header="Subtotal"     Binding="{Binding ImporteTexto}"    Width="110" />
                                    <DataGridTemplateColumn Width="46" CanUserResize="False" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Command="{Binding DataContext.QuitarLineaCommand,
                                                                     RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           CommandParameter="{Binding}"
                                                           Style="{StaticResource AccionIconButtonCompact}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Quitar este ítem">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                                </ui:Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Descripción" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="11" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding DescripcionLinea, UpdateSourceTrigger=PropertyChanged}" Width="200" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Cantidad" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="11" Margin="0,0,0,2" />
                                    <ui:NumberBox Value="{Binding CantidadLinea, UpdateSourceTrigger=PropertyChanged}"
                                                  Minimum="0.001" Maximum="1000000000" ClearButtonEnabled="False"
                                                  SpinButtonPlacementMode="Hidden" Width="80" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Precio unit." Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="11" Margin="0,0,0,2" />
                                    <ui:NumberBox Value="{Binding PrecioUnitarioLinea, UpdateSourceTrigger=PropertyChanged}"
                                                  Minimum="0" Maximum="1000000000" ClearButtonEnabled="False"
                                                  SpinButtonPlacementMode="Hidden" Width="120" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" Margin="0,0,8,8">
                                    <ui:Button Content="Agregar ítem" Command="{Binding AgregarLineaCommand}"
                                               Style="{StaticResource AccionIconButton}"
                                               ToolTip="Agregar este ítem al grupo">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Selector de empresas -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8" IsEnabled="{Binding EnEdicion}">
                        <TextBlock Text="Miembros" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <DockPanel>
                            <ui:Button DockPanel.Dock="Right"
                                       Content="Agregar" Command="{Binding AgregarMiembroCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Agregar empresa seleccionada al grupo">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                            </ui:Button>
                            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                      Text="{Binding FiltroMiembros, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding ClientesDisponibles}"
                                      SelectedItem="{Binding ClienteSeleccionada}"
                                      DisplayMemberPath="Nombre" />
                        </DockPanel>
                    </StackPanel>

                    <!-- Lista de miembros del grupo -->
                    <ListBox Grid.Row="4" ItemsSource="{Binding MiembrosDelGrupo}" IsEnabled="{Binding EnEdicion}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="6,2" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel MinWidth="0">
                                    <ui:Button DockPanel.Dock="Right"
                                               Command="{Binding DataContext.QuitarMiembroCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListBox}}"
                                               CommandParameter="{Binding}"
                                               MinHeight="24" Padding="4,4"
                                               Style="{StaticResource AccionIconButtonCompact}"
                                               VerticalAlignment="Center"
                                               ToolTip="Quitar del grupo">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <TextBlock Text="{Binding Nombre}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="5" Margin="0,12,0,0">
                        <WrapPanel Margin="0,0,0,8">
                            <ui:Button Content="Nuevo" Command="{Binding NuevoCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Crear un nuevo grupo de facturación">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Editar" Command="{Binding EditarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Editar el grupo seleccionado">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Eliminar el grupo seleccionado">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                        <WrapPanel>
                            <ui:Button Content="Aceptar" Command="{Binding AceptarCommand}"
                                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0,0,8,8"
                                       ToolTip="Guardar los cambios del grupo">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Cancelar la edición">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
