<Page x:Class="CamaraPortuaria.UI.Views.EmisionMasivaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Emisión masiva">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Emisión masiva por grupo" Style="{StaticResource PageTitle}" />

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,8"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Grupo:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding Grupos}" SelectedItem="{Binding Grupo}" DisplayMemberPath="Nombre" Width="240" />
            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="16,0,8,0" />
            <ComboBox ItemsSource="{Binding MesesNombres}" SelectedIndex="{Binding MesIndex}" Width="110" />
            <StackPanel Orientation="Horizontal" Margin="8,0,8,0" VerticalAlignment="Center">
                <RepeatButton Content="−" Command="{Binding DecrementarAnioCommand}" Width="28" Height="28"
                              FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                <TextBox Text="{Binding Anio, UpdateSourceTrigger=PropertyChanged}" Width="60"
                         TextAlignment="Center" VerticalContentAlignment="Center" Margin="4,0" />
                <RepeatButton Content="+" Command="{Binding IncrementarAnioCommand}" Width="28" Height="28"
                              FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
            </StackPanel>
            <Button Content="Emitir" Command="{Binding EmitirCommand}"
                    Style="{StaticResource PrimaryButton}" />
        </StackPanel>

        <!-- Previa del estado antes de emitir (EMI-1) -->
        <Border Grid.Row="3" Margin="0,0,0,12" Padding="12" CornerRadius="8"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                Visibility="{Binding HayPrevia, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding ResumenPrevia}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <DataGrid ItemsSource="{Binding PreviaItems}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" MaxHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Empresa" Binding="{Binding Empresa}" Width="*" />
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="120" />
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding YaEmitido}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <DataGrid ItemsSource="{Binding Resultados}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Empresa" Binding="{Binding EntidadNombre}" Width="*" />
                    <DataGridTextColumn Header="Nro." Binding="{Binding NumeroComprobante}" Width="100" />
                    <DataGridCheckBoxColumn Header="Éxito" Binding="{Binding Exito}" Width="70" />
                    <DataGridTextColumn Header="Error emisión" Binding="{Binding ErrorEmision}" Width="*" />
                    <DataGridTextColumn Header="Error mail" Binding="{Binding ErrorMail}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="{DynamicResource SmokeFillColorDefaultBrush}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="6" />
                    <TextBlock Text="Emitiendo recibos…" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
