<Page x:Class="CamaraPortuaria.UI.Views.RecibosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:CamaraPortuaria.UI.Controls"
      Title="Recibos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recibos" Style="{StaticResource PageTitle}" />

        <!-- Filtros período -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding MesesNombres}" SelectedIndex="{Binding MesIndex}" Width="110" />
                <ui:NumberBox Value="{Binding Anio, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource YearNumberBox}" Margin="8,0,0,0" />
            </StackPanel>
            <ui:TextBox PlaceholderText="Buscar en recibos..."
                        Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                        Width="200" Margin="0,0,8,8" VerticalAlignment="Center">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:TextBox.Icon>
            </ui:TextBox>
            <ui:Button Content="Nuevo recibo" Command="{Binding AbrirEmisionIndividualCommand}"
                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0,0,8,8"
                       ToolTip="Emitir un recibo individual a una empresa específica.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="AddSquare24" /></ui:Button.Icon>
            </ui:Button>
        </WrapPanel>

        <!-- Acciones sobre el recibo seleccionado en la grilla -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <ui:Button Content="Emitir CAE" Command="{Binding ReintentarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Emitir / reintentar la emisión (obtener CAE) del recibo seleccionado">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Editar" Command="{Binding EditarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Editar los ítems de un recibo Pendiente (sin CAE)">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Eliminar un recibo Pendiente (sin CAE) para rehacerlo">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Enviar mail" Command="{Binding ReenviarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Enviar por mail el recibo seleccionado; si está anulado, envía la nota de crédito">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Mail24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Marcar pagado" Command="{Binding MarcarPagadoCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Marcar el recibo seleccionado como pagado">
                <ui:Button.Icon><ui:SymbolIcon Symbol="CheckmarkCircle24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Ver PDF" Command="{Binding PrevisualizarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Previsualizar el PDF del recibo seleccionado">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentPdf24" /></ui:Button.Icon>
            </ui:Button>
            <Separator Margin="0,0,8,8" />
            <ui:Button Content="Anular" Command="{Binding AnularCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Anular el recibo emitiendo una nota de crédito, sin enviar mail">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Prohibited24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Anular y enviar" Command="{Binding AnularYEnviarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Anular el recibo emitiendo una nota de crédito y enviarla por mail">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Send24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="PDF NC" Command="{Binding PrevisualizarNotaCreditoCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Previsualizar el PDF de la nota de crédito del recibo anulado">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentPdf24" /></ui:Button.Icon>
            </ui:Button>
        </WrapPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Recibos}" SelectedItem="{Binding Seleccionado}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  SelectionMode="Single"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Empresa" Binding="{Binding Cliente}" Width="*" />
                <DataGridTextColumn Header="Comprobante" Binding="{Binding Comprobante}" Width="120" />
                <DataGridTextColumn Header="CAE" Binding="{Binding Cae}" Width="140" />
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="110" />
                <DataGridTextColumn Header="Emisión" Binding="{Binding FechaEmision}" Width="90" />
                <DataGridTemplateColumn Header="Estado" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Estado, Converter={StaticResource EstadoReciboToBrushConverter}}"
                                    CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" Margin="4,0">
                                <TextBlock Text="{Binding Estado}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding Estado, Converter={StaticResource EstadoReciboToFgBrushConverter}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Estado envío" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EstadoEnvio}" ToolTip="{Binding Error}"
                                       VerticalAlignment="Center" Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <controls:BusyOverlay Grid.RowSpan="4" />
    </Grid>
</Page>
