<Page x:Class="CamaraPortuaria.UI.Views.RecibosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Recibos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recibos" Style="{StaticResource PageTitle}" />

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,8"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <!-- Filtros período -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding Meses}" SelectedItem="{Binding Mes}" Width="70" />
            <ComboBox ItemsSource="{Binding Anios}" SelectedItem="{Binding Anio}" Width="90" Margin="8,0,0,0" />
            <Button Content="Buscar" Command="{Binding BuscarCommand}"
                    Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
            <Button Content="Anular" Command="{Binding AnularCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
            <Button Content="Reenviar" Command="{Binding ReenviarCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
            <Button Content="Marcar pagado" Command="{Binding MarcarPagadoCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Recibos}" SelectedItem="{Binding Seleccionado}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Empresa" Binding="{Binding Empresa}" Width="*" />
                <DataGridTextColumn Header="Comprobante" Binding="{Binding Comprobante}" Width="120" />
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120" />
                <DataGridTextColumn Header="Emisión" Binding="{Binding FechaEmision}" Width="100" />
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100" />
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background"
                            Value="{Binding Estado, Converter={StaticResource EstadoReciboToBrushConverter}}" />
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Emisión individual -->
        <Border Grid.Row="4" Margin="0,16,0,0" Padding="16" CornerRadius="8"
                Background="{DynamicResource LayerFillColorDefaultBrush}">
            <StackPanel>
                <TextBlock Text="Emisión individual" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Empresas}" SelectedItem="{Binding EmpresaEmision}"
                              DisplayMemberPath="Nombre" Width="240" />
                    <TextBox Text="{Binding ImporteEmision, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="8,0,0,0"
                             ToolTip="Importe" />
                    <TextBox Text="{Binding DetalleEmision, UpdateSourceTrigger=PropertyChanged}" Width="260" Margin="8,0,0,0"
                             ToolTip="Detalle" />
                    <Button Content="Emitir" Command="{Binding EmitirIndividualCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

