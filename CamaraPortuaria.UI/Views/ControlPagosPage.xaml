<Page x:Class="CamaraPortuaria.UI.Views.ControlPagosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Control de pagos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Control de pagos" Style="{StaticResource PageTitle}" />

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,8"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <CheckBox Content="Solo vencidos" IsChecked="{Binding SoloVencidos}" VerticalAlignment="Center" />
            <Button Content="Actualizar" Command="{Binding BuscarCommand}" Margin="8,0,0,0"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="Marcar pagado" Command="{Binding MarcarPagadoCommand}"
                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" />
            <Button Content="Reenviar mail" Command="{Binding ReenviarCommand}"
                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" />
            <TextBlock Text="{Binding Resumen}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <DataGrid ItemsSource="{Binding Recibos}" SelectedItem="{Binding Seleccionado}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Empresa" Binding="{Binding Empresa}" Width="*" />
                    <DataGridTextColumn Header="Comprobante" Binding="{Binding Comprobante}" Width="120" />
                    <DataGridTextColumn Header="Período" Binding="{Binding Periodo}" Width="120" />
                    <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120" />
                    <DataGridTextColumn Header="Vencimiento" Binding="{Binding FechaVencimiento}" Width="110" />
                    <DataGridTextColumn Header="Atraso (días)" Binding="{Binding DiasAtraso}" Width="100" />
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100" />
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background"
                                Value="{Binding Estado, Converter={StaticResource EstadoReciboToBrushConverter}}" />
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <Border Background="{DynamicResource SmokeFillColorDefaultBrush}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6" VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Page>
