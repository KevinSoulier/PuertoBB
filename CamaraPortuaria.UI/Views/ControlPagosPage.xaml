<Page x:Class="CamaraPortuaria.UI.Views.ControlPagosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:CamaraPortuaria.UI.Controls"
      Title="Control">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Control" Style="{StaticResource PageTitle}" />

        <!-- Fila de filtros -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <ui:TextBox PlaceholderText="Buscar en pagos..."
                        Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                        Width="220" VerticalAlignment="Center" Margin="0,0,8,8">
                <ui:TextBox.Icon><ui:SymbolIcon Symbol="Search24" /></ui:TextBox.Icon>
            </ui:TextBox>
            <ComboBox ItemsSource="{Binding EstadosFiltro}" SelectedItem="{Binding FiltroEstado}"
                      Width="180" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox Content="Solo vencidos" IsChecked="{Binding SoloVencidos}"
                      VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox Content="Incluir incobrables" IsChecked="{Binding IncluirIncobrables}"
                      VerticalAlignment="Center" Margin="0,0,0,8" />
        </WrapPanel>

        <!-- Fila de acciones -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,12">
            <ui:Button Content="Actualizar" Command="{Binding BuscarCommand}"
                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0,0,8,8"
                       ToolTip="Actualizar la lista de pagos">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Marcar pagado" Command="{Binding MarcarPagadoCommand}"
                       Margin="0,0,8,8" Style="{StaticResource AccionIconButton}"
                       ToolTip="Marcar el recibo seleccionado como pagado">
                <ui:Button.Icon><ui:SymbolIcon Symbol="CheckmarkCircle24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Reenviar mail" Command="{Binding ReenviarCommand}"
                       Margin="0,0,8,8" Style="{StaticResource AccionIconButton}"
                       ToolTip="Reenviar el recibo seleccionado por correo">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Mail24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Marcar incobrable" Command="{Binding MarcarIncobrableCommand}"
                       Margin="0,0,8,8" Style="{StaticResource AccionIconButton}"
                       ToolTip="Dar de baja la deuda del recibo seleccionado (incobrable)">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Warning24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Quitar incobrable" Command="{Binding QuitarIncobrableCommand}"
                       Margin="0,0,8,8" Style="{StaticResource AccionIconButton}"
                       ToolTip="Reactivar la deuda de un recibo marcado como incobrable">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button.Icon>
            </ui:Button>
            <TextBlock Text="{Binding Resumen}" VerticalAlignment="Center" Margin="8,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </WrapPanel>

        <Grid Grid.Row="4">
            <DataGrid x:Name="RecibosGrid"
                      ItemsSource="{Binding Recibos}" SelectedItem="{Binding Seleccionado}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False"
                      SelectionMode="Extended"
                      SelectionChanged="Recibos_SelectionChanged"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Empresa" Binding="{Binding Empresa}" Width="*" />
                    <DataGridTextColumn Header="Comprobante" Binding="{Binding Comprobante}" Width="120" />
                    <DataGridTextColumn Header="Período" Binding="{Binding Periodo}" Width="120" />
                    <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120" />
                    <DataGridTextColumn Header="Emisión" Binding="{Binding FechaEmision}" Width="110" />
                    <DataGridTextColumn Header="Vencimiento" Binding="{Binding FechaVencimiento}" Width="110" />
                    <DataGridTextColumn Header="Atraso (días)" Binding="{Binding DiasAtraso}" Width="100" />
                    <DataGridTemplateColumn Header="Estado" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Estado, Converter={StaticResource EstadoReciboToBrushConverter}}"
                                        CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" Margin="4,0">
                                    <TextBlock Text="{Binding Estado}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding Estado, Converter={StaticResource EstadoReciboToFgBrushConverter}}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Fila de paginado -->
        <WrapPanel Grid.Row="5" Margin="0,12,0,0" VerticalAlignment="Center">
            <ui:Button Content="« Primera" Command="{Binding PrimeraCommand}" Margin="0,0,4,0"
                       ToolTip="Primera página" />
            <ui:Button Content="‹ Anterior" Command="{Binding AnteriorCommand}" Margin="0,0,4,0"
                       ToolTip="Página anterior" />
            <TextBlock VerticalAlignment="Center" Margin="8,0">
                <Run Text="Página " /><Run Text="{Binding PaginaActual, Mode=OneWay}" /><Run Text=" de " /><Run Text="{Binding TotalPaginas, Mode=OneWay}" />
            </TextBlock>
            <ui:Button Content="Siguiente ›" Command="{Binding SiguienteCommand}" Margin="4,0,4,0"
                       ToolTip="Página siguiente" />
            <ui:Button Content="Última »" Command="{Binding UltimaCommand}" Margin="0,0,16,0"
                       ToolTip="Última página" />
            <TextBlock Text="Por página:" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ComboBox ItemsSource="{Binding TamaniosPagina}" SelectedItem="{Binding TamanioPagina}"
                      Width="80" VerticalAlignment="Center" />
        </WrapPanel>

        <controls:BusyOverlay Grid.RowSpan="6" />
    </Grid>
</Page>
