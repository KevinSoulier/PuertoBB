<Page x:Class="CamaraPortuaria.UI.Views.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Configuración"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración" Style="{StaticResource PageTitle}"
                   Margin="24,24,24,8" />

        <TabControl Grid.Row="1" Margin="24,0,24,0" Background="Transparent" BorderThickness="0">

            <!-- ══════════════════════════════════════════
                 AFIP / ARCA
                 ══════════════════════════════════════════ -->
            <TabItem Header="AFIP / ARCA">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <Grid Margin="0,12,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Sección: Datos del emisor -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                                <TextBlock Text="Datos del emisor" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <!-- Campos en línea que se apilan al no entrar en el ancho (MaxWidth=640 del contenedor) -->
                                <WrapPanel Margin="0,0,0,8">
                                    <StackPanel Width="300" Margin="0,0,16,8">
                                        <TextBlock Text="Razón social" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding RazonSocial, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding EmisorEditando}" />
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="0,0,16,8">
                                        <TextBlock Text="CUIT" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding Cuit, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding EmisorEditando}" />
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="0,0,16,8">
                                        <TextBlock Text="Ingresos Brutos" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding IngresosBrutos, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding EmisorEditando}" />
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="0,0,16,8">
                                        <TextBlock Text="Inicio de Actividades" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <DatePicker SelectedDate="{Binding InicioActividades, UpdateSourceTrigger=PropertyChanged}"
                                                    IsEnabled="{Binding EmisorEditando}" />
                                    </StackPanel>
                                </WrapPanel>
                                <!-- Barra Editar/Guardar/Cancelar -->
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="Editar" Command="{Binding EditarEmisorCommand}"
                                               Style="{StaticResource AccionIconButton}"
                                               Visibility="{Binding EmisorNoEditando, Converter={StaticResource BoolToVis}}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Guardar" Command="{Binding GuardarEmisorCommand}"
                                               Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                               Visibility="{Binding EmisorEditando, Converter={StaticResource BoolToVis}}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Cancelar" Command="{Binding CancelarEmisorCommand}"
                                               Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               Visibility="{Binding EmisorEditando, Converter={StaticResource BoolToVis}}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </StackPanel>
                            <Separator Margin="0,12,0,8" />
                        </StackPanel>

                        <!-- Sección: Códigos AFIP -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,8">
                            <WrapPanel Margin="0,0,0,8">
                                <StackPanel Margin="0,0,16,8">
                                    <TextBlock Text="Comprobante a emitir" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding ComprobantesDisponibles}"
                                              DisplayMemberPath="Display"
                                              SelectedValuePath="Codigo"
                                              SelectedValue="{Binding CodigoAfipRecibo}"
                                              IsEnabled="{Binding CodigosAfipEditando}" Width="200" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,8">
                                    <TextBlock Text="Nota de Crédito (automática)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding NotaDeCreditoDisplay}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                </StackPanel>
                            </WrapPanel>
                            <!-- Barra Editar/Guardar/Cancelar (Códigos) -->
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Editar" Command="{Binding EditarCodigosAfipCommand}"
                                           Style="{StaticResource AccionIconButton}"
                                           Visibility="{Binding CodigosAfipNoEditando, Converter={StaticResource BoolToVis}}">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Guardar" Command="{Binding GuardarCodigosAfipCommand}"
                                           Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                           Visibility="{Binding CodigosAfipEditando, Converter={StaticResource BoolToVis}}">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Content="Cancelar" Command="{Binding CancelarCodigosAfipCommand}"
                                           Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                           Visibility="{Binding CodigosAfipEditando, Converter={StaticResource BoolToVis}}">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Separador y header Puntos de venta -->
                        <StackPanel Grid.Row="2" Margin="0,8,0,8">
                            <Separator Margin="0,0,0,8" />
                            <TextBlock Text="Puntos de venta" FontWeight="SemiBold" Margin="0,0,0,2" />
                            <TextBlock Text="Cargá uno o más puntos de venta (ej. uno de homologación y otro de producción) y marcá cuál está activo. El activo define el número, el ambiente y el certificado que usa la app al emitir."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                        </StackPanel>

                        <!-- Layout master-detail: formulario izquierda | lista derecha -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Columna izquierda: formulario de alta/edición (IsEnabled deshabilita campos internos) -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="16"
                                        IsEnabled="{Binding PvFormEditando}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TituloEdicion}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <!-- Campos del punto de venta: ancho uniforme (estiran al ancho del formulario) -->
                                        <TextBlock Text="Nombre" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding EdNombre, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                        <CheckBox Content="Usar homologación (solo pruebas)" IsChecked="{Binding EdUsarHomologacion}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding AmbienteEdicion}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,8" />
                                        <TextBlock Text="Número de punto de venta" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding EdNumero, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                        <TextBlock Text="Tipo de certificado" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        <RadioButton Content="P12 (con contraseña)" IsChecked="{Binding EdModoP12}" />
                                        <RadioButton Content="CRT + KEY (sin contraseña)" IsChecked="{Binding EdModoCrtKey}" Margin="0,0,0,8" />
                                        <ui:Button Content="Generar certificado nuevo…" Command="{Binding GenerarCertificadoCommand}"
                                                   Style="{StaticResource AccionIconButton}" Margin="0,0,0,8"
                                                   ToolTip="Crea la clave privada y el CSR para tramitar un certificado en AFIP. Al terminar, la clave queda cargada en modo CRT+KEY.">
                                            <ui:Button.Icon><ui:SymbolIcon Symbol="Key24" /></ui:Button.Icon>
                                        </ui:Button>
                                        <!-- Modo P12 -->
                                        <StackPanel Visibility="{Binding EdModoP12, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Certificado (.p12)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding EdCertificadoRuta}" IsReadOnly="True"
                                                         VerticalAlignment="Center" ToolTip="{Binding EdCertificadoRuta}" />
                                                <ui:Button Grid.Column="1" Content="Examinar…" Command="{Binding SeleccionarCertificadoCommand}"
                                                           Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                            <TextBlock Text="Contraseña del certificado" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <PasswordBox x:Name="CertPasswordBox" Grid.Column="0"
                                                             Visibility="{Binding EdOcultarPassword, Converter={StaticResource BoolToVis}}"
                                                             PasswordChanged="CertPasswordBox_PasswordChanged"/>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding EdCertificadoPassword, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding EdMostrarPassword, Converter={StaticResource BoolToVis}}"/>
                                                <ui:Button Grid.Column="1"
                                                           Command="{Binding ToggleMostrarPasswordCommand}"
                                                           Style="{StaticResource AccionIconButton}"
                                                           Margin="8,0,0,0"
                                                           ToolTip="Mostrar/ocultar contraseña">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Eye24"/></ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                        </StackPanel>
                                        <!-- Modo CRT + KEY -->
                                        <StackPanel Visibility="{Binding EdModoCrtKey, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Certificado (.crt / .pem)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding EdCertificadoRuta}" IsReadOnly="True"
                                                         VerticalAlignment="Center" ToolTip="{Binding EdCertificadoRuta}" />
                                                <ui:Button Grid.Column="1" Content="Examinar…" Command="{Binding SeleccionarCertificadoCommand}"
                                                           Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                            <TextBlock Text="Clave privada (.key / .pem)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding EdCertificadoKeyRuta}" IsReadOnly="True"
                                                         VerticalAlignment="Center" ToolTip="{Binding EdCertificadoKeyRuta}" />
                                                <ui:Button Grid.Column="1" Content="Examinar…" Command="{Binding SeleccionarClaveKeyCommand}"
                                                           Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Key24" /></ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                            <WrapPanel Margin="0,8,0,0">
                                                <ui:Button Content="Descargar .crt…" Command="{Binding DescargarCrtCommand}" IsEnabled="{Binding EdTieneCrt}"
                                                           Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                                           ToolTip="Guarda el certificado (.crt) cargado a un archivo.">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                                </ui:Button>
                                                <ui:Button Content="Descargar .key…" Command="{Binding DescargarKeyCommand}" IsEnabled="{Binding EdTieneKey}"
                                                           Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                                           ToolTip="Guarda la clave privada (.key) a un archivo. Útil para respaldo si el certificado se generó en la app.">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                                </ui:Button>
                                                <ui:Button Content="Exportar .p12…" Command="{Binding ExportarP12Command}" IsEnabled="{Binding EdPuedeExportarP12}"
                                                           Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                                           ToolTip="Combina el .crt y la clave en un único archivo .p12 protegido por contraseña.">
                                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                                </ui:Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Botones FUERA del Border: Guardar/Cancelar (Nuevo y Editar van arriba de la lista) -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <ui:Button Content="Guardar punto" Command="{Binding GuardarPuntoCommand}"
                                               Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                               Visibility="{Binding PvFormEditando, Converter={StaticResource BoolToVis}}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Cancelar" Command="{Binding CancelarPuntoCommand}"
                                               Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               Visibility="{Binding PvFormEditando, Converter={StaticResource BoolToVis}}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Columna derecha: lista y acciones (deshabilitadas mientras se edita un punto: PvFormNoEditando) -->
                            <StackPanel Grid.Column="2">
                                <DataGrid ItemsSource="{Binding PuntosDeVenta}" SelectedItem="{Binding PuntoSeleccionado}"
                                          IsEnabled="{Binding PvFormNoEditando}"
                                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                          CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                                          Height="180" Margin="0,0,0,6" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="" Binding="{Binding ActivoTexto}" Width="80" />
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                                        <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="70" />
                                        <DataGridTextColumn Header="Ambiente" Binding="{Binding Ambiente}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ui:Button Content="Nuevo" Command="{Binding NuevoPuntoCommand}" Style="{StaticResource AccionIconButton}"
                                               IsEnabled="{Binding PvFormNoEditando}"
                                               ToolTip="Agregar un nuevo punto de venta">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Editar" Command="{Binding EditarPuntoCommand}" Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               IsEnabled="{Binding PvFormNoEditando}"
                                               ToolTip="Editar el punto de venta seleccionado">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Marcar activo" Command="{Binding MarcarActivoCommand}" Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               IsEnabled="{Binding PvFormNoEditando}"
                                               ToolTip="Usar este punto de venta para emitir (solo uno puede estar activo)">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Checkmark24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Eliminar" Command="{Binding EliminarPuntoCommand}" Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               IsEnabled="{Binding PvFormNoEditando}"
                                               ToolTip="Eliminar el punto de venta seleccionado">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Probar conexión" Command="{Binding ProbarConexionCommand}" Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                               IsEnabled="{Binding PvFormNoEditando}"
                                               ToolTip="Verificar el servicio AFIP y la autenticación con el certificado">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="PlugConnected24" /></ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                                <TextBlock Text="{Binding EstadoConexion}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 PAGOS
                 ══════════════════════════════════════════ -->
            <TabItem Header="Pagos">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left" Margin="0,12,0,12">
                        <TextBlock Text="Días de vencimiento" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DiasVencimiento, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding PagosEditando}"
                                 Width="100" HorizontalAlignment="Left" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Editar" Command="{Binding EditarPagosCommand}"
                                       Style="{StaticResource AccionIconButton}"
                                       Visibility="{Binding PagosNoEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Guardar" Command="{Binding GuardarPagosCommand}"
                                       Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                       Visibility="{Binding PagosEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Cancelar" Command="{Binding CancelarPagosCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       Visibility="{Binding PagosEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 CORREO
                 ══════════════════════════════════════════ -->
            <TabItem Header="Correo">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left" Margin="0,12,0,12">
                        <TextBlock Text="Servidor" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Puerto" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CorreoEditando}" Width="100" />
                            </StackPanel>
                            <StackPanel Margin="16,0,0,0">
                                <TextBlock Text="Seguridad" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                <ComboBox SelectedIndex="{Binding SmtpSeguridad, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding CorreoEditando}" Width="160">
                                    <ComboBoxItem Content="Auto (recomendado)" />
                                    <ComboBoxItem Content="SSL/TLS (puerto 465)" />
                                    <ComboBoxItem Content="Sin cifrado" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="16,0,0,0">
                                <TextBlock Text="Email remitente" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                <ui:TextBox Text="{Binding EmailRemitente, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="ej. info@tudominio.com"
                                            IsEnabled="{Binding CorreoEditando}" Width="220" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Modo de autenticación -->
                        <TextBlock Text="Autenticación" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox SelectedIndex="{Binding Autenticacion, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding CorreoEditando}" Width="260" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <ComboBoxItem Content="Ninguna" />
                            <ComboBoxItem Content="Básica (usuario y contraseña)" />
                            <ComboBoxItem Content="OAuth2 (Microsoft, Google…)" />
                        </ComboBox>

                        <!-- Autenticación básica -->
                        <StackPanel Visibility="{Binding EsBasica, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Usuario" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SmtpUsuario, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />
                            <TextBlock Text="Contraseña" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <PasswordBox x:Name="SmtpPasswordBox" IsEnabled="{Binding CorreoEditando}"
                                         Margin="0,0,0,16" PasswordChanged="SmtpPasswordBox_PasswordChanged" />
                        </StackPanel>

                        <!-- Autenticación OAuth2 -->
                        <StackPanel Visibility="{Binding EsOAuth2, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Proveedor" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                    <ComboBox SelectedIndex="{Binding OAuthProveedor, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding CorreoEditando}" Width="200">
                                        <ComboBoxItem Content="Microsoft 365 (empresa)" />
                                        <ComboBoxItem Content="Google / Gmail" />
                                        <ComboBoxItem Content="Personalizado" />
                                        <ComboBoxItem Content="Outlook.com (personal)" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Text="Flujo" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Interactivo (navegador)" GroupName="OAuthFlujo"
                                                     IsChecked="{Binding OAuthFlujoInteractivo}" IsEnabled="{Binding CorreoEditando}" />
                                        <RadioButton Content="Cliente (sin navegador)" GroupName="OAuthFlujo" Margin="12,0,0,0"
                                                     IsChecked="{Binding OAuthFlujoCliente}" IsEnabled="{Binding CorreoEditando}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Client ID" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding OAuthClientId, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />

                            <TextBlock Text="Tenant ID (Microsoft; vacío = común)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding OAuthTenantId, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />

                            <TextBlock Text="Client Secret (requerido para «Cliente»)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <PasswordBox x:Name="OAuthClientSecretBox" IsEnabled="{Binding CorreoEditando}"
                                         Margin="0,0,0,8" PasswordChanged="OAuthClientSecretBox_PasswordChanged" />

                            <!-- Endpoints: solo proveedor Personalizado -->
                            <StackPanel Visibility="{Binding EsProveedorPersonalizado, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Authorize endpoint" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding OAuthAuthorizeEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />
                                <TextBlock Text="Token endpoint" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding OAuthTokenEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,8" />
                            </StackPanel>

                            <TextBlock Text="Scope (vacío = el del proveedor)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding OAuthScope, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CorreoEditando}" Margin="0,0,0,12" />

                            <!-- Flujo interactivo: iniciar sesión en el navegador -->
                            <StackPanel Visibility="{Binding EsFlujoInteractivo, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                                <ui:Button Content="Iniciar sesión…" Command="{Binding IniciarSesionOAuthCommand}"
                                           Style="{StaticResource AccionIconButton}" IsEnabled="{Binding CorreoEditando}"
                                           HorizontalAlignment="Left"
                                           ToolTip="Abre el navegador para consentir una vez. Después guardá la configuración.">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Person24" /></ui:Button.Icon>
                                </ui:Button>
                                <TextBlock Text="{Binding OAuthEstado}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:Button Content="Editar" Command="{Binding EditarCorreoCommand}"
                                       Style="{StaticResource AccionIconButton}"
                                       Visibility="{Binding CorreoNoEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Guardar" Command="{Binding GuardarCorreoCommand}"
                                       Style="{StaticResource AccionIconButton}" Appearance="Primary"
                                       Visibility="{Binding CorreoEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Cancelar" Command="{Binding CancelarCorreoCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       Visibility="{Binding CorreoEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Probar conexión" Command="{Binding ProbarMailCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Enviar un correo de prueba con la configuración SMTP actual"
                                       Visibility="{Binding CorreoNoEditando, Converter={StaticResource BoolToVis}}">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="PlugConnected24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>
                        <TextBlock Text="{Binding EstadoCorreo}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 APARIENCIA  (sin botón — aplica al instante)
                 ══════════════════════════════════════════ -->
            <TabItem Header="Apariencia">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left" Margin="0,12,0,12">
                        <TextBlock Text="Tema" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox x:Name="ThemeSelector" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8"
                                  SelectionChanged="ThemeSelector_SelectionChanged">
                            <ComboBoxItem Content="Claro" />
                            <ComboBoxItem Content="Oscuro" />
                            <ComboBoxItem Content="Seguir al sistema" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════
                 BASE DE DATOS
                 ══════════════════════════════════════════ -->
            <TabItem Header="Base de datos">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left" Margin="0,12,0,12">

                        <!-- Backup -->
                        <TextBlock Text="Backup" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Generá una copia de seguridad de la base o restaurá desde una copia existente. Al restaurar la aplicación se cerrará automáticamente."
                                   TextWrapping="Wrap" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <ui:Button Content="Generar backup…" Command="{Binding BackupCommand}"
                                       Style="{StaticResource AccionIconButton}"
                                       ToolTip="Guardar una copia de seguridad de la base de datos en disco.">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Restaurar backup…" Command="{Binding RestaurarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Reemplazar la base actual por una copia de seguridad previa.">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUpload24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>

                        <!-- Mantenimiento -->
                        <Separator Margin="0,0,0,12" />
                        <TextBlock Text="Mantenimiento" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Herramientas para verificar y optimizar la base de datos. Usar si la app se comporta de forma inesperada o después de fallos."
                                   TextWrapping="Wrap" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Verificar integridad" Command="{Binding VerificarIntegridadCommand}"
                                       Style="{StaticResource AccionIconButton}"
                                       ToolTip="Comprobar que el archivo de la base de datos no esté dañado.">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="ShieldCheckmark24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Compactar (VACUUM)" Command="{Binding VacuumCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Reconstruye el archivo de la base de datos, recupera espacio y rehace los índices.">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Optimizar consultas" Command="{Binding OptimizarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                                       ToolTip="Actualiza las estadísticas internas para mejorar la performance de las consultas.">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Flash24" /></ui:Button.Icon>
                            </ui:Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
