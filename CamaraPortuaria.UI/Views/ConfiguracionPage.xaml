<Page x:Class="CamaraPortuaria.UI.Views.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Configuración">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Configuración" Style="{StaticResource PageTitle}" />

            <Border Margin="0,0,0,12" Padding="12,8"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                    Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="Emisor" FontWeight="SemiBold" Margin="0,8,0,6" />
            <TextBlock Text="Razón social" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding RazonSocial, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="CUIT" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding Cuit, UpdateSourceTrigger=PropertyChanged}" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8" />
            <TextBlock Text="Punto de venta" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding PuntoDeVenta, UpdateSourceTrigger=PropertyChanged}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8" />

            <TextBlock Text="AFIP / ARCA" FontWeight="SemiBold" Margin="0,12,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Código Recibo" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding CodigoAfipRecibo, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Código Nota de Crédito" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding CodigoAfipNotaDeCredito, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Certificado (.p12)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Text="{Binding AfipCertificadoRuta}" Width="420" IsReadOnly="True" />
                <Button Content="Examinar…" Command="{Binding SeleccionarCertificadoCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="Contraseña del certificado" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <PasswordBox x:Name="CertPasswordBox" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8"
                         PasswordChanged="CertPasswordBox_PasswordChanged" />
            <CheckBox Content="Usar homologación (solo pruebas)" IsChecked="{Binding AfipUsarHomologacion}" Margin="0,4,0,8" />

            <TextBlock Text="Pagos" FontWeight="SemiBold" Margin="0,12,0,6" />
            <TextBlock Text="Días de vencimiento" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding DiasVencimiento, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8" />

            <TextBlock Text="Correo saliente (SMTP)" FontWeight="SemiBold" Margin="0,12,0,6" />
            <TextBlock Text="Servidor" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Puerto" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Remitente" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EmailRemitente, UpdateSourceTrigger=PropertyChanged}" Width="280" />
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Usuario" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding SmtpUsuario, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Contraseña" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <PasswordBox x:Name="SmtpPasswordBox" Margin="0,0,0,8" PasswordChanged="SmtpPasswordBox_PasswordChanged" />

            <TextBlock Text="Apariencia" FontWeight="SemiBold" Margin="0,12,0,6" />
            <TextBlock Text="Tema" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="ThemeSelector" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8"
                      SelectionChanged="ThemeSelector_SelectionChanged">
                <ComboBoxItem Content="Claro" />
                <ComboBoxItem Content="Oscuro" />
                <ComboBoxItem Content="Seguir al sistema" />
            </ComboBox>

            <TextBlock Text="Base de datos" FontWeight="SemiBold" Margin="0,12,0,6" />
            <Button Content="Generar backup…" Command="{Binding BackupCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,0,0,8" />

            <Button Content="Guardar configuración" Command="{Binding GuardarCommand}"
                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,12,0,24" />
        </StackPanel>
    </ScrollViewer>
</Page>

