<UserControl x:Class="CentroMaritimo.UI.Dialogs.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="8" MinWidth="340" MaxWidth="480"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
            Effect="{DynamicResource ElevationShadow16Effect}"
            Padding="24">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" MinWidth="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button x:Name="ConfirmButton" MinWidth="90" Click="Confirm_Click"
                        Style="{DynamicResource AccentButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

