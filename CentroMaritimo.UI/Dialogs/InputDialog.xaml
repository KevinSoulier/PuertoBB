<UserControl x:Class="CentroMaritimo.UI.Dialogs.InputDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="8" MinWidth="340" MaxWidth="480"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
            Padding="24">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBox x:Name="InputBox" FontSize="14" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancelar" MinWidth="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button x:Name="OkButton" Content="Aceptar" MinWidth="90" Click="Ok_Click"
                        Style="{DynamicResource AccentButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

