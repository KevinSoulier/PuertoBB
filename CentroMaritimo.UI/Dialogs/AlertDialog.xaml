<UserControl x:Class="CentroMaritimo.UI.Dialogs.AlertDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="8" MinWidth="340" MaxWidth="480"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
            Padding="24">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,20"/>
            <Button x:Name="CloseButton" MinWidth="90" HorizontalAlignment="Right" Click="Close_Click"
                    Style="{DynamicResource AccentButtonStyle}"/>
        </StackPanel>
    </Border>
</UserControl>

