<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- DatePicker: hereda el template Fluent de WPF-UI (BasedOn) y solo ajusta fondo sólido
         para contraste sobre Mica/Acrylic. Sin BasedOn, WPF cae al template clásico (sin estilo). -->
    <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="36" />
        <!-- Estira el textbox interno para que el campo ocupe todo el ancho asignado (Width),
             tenga o no fecha seleccionada. Sin esto, el template Fluent encoge el campo
             al watermark cuando está vacío y queda más angosto que el resto. -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <!-- ui:CalendarDatePicker Fluent: mismo fondo sólido para que no se transparente sobre Mica -->
    <Style TargetType="{x:Type ui:CalendarDatePicker}" BasedOn="{StaticResource {x:Type ui:CalendarDatePicker}}">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <!-- Altura uniforme (36px) para inputs en filas: así quedan alineados con los botones y
         entre sí. Usamos MinHeight (no Height fijo) para que el contenido nunca quede recortado.
         Los valores Height locales (p. ej. TextBox multilínea) siguen ganando sobre estos setters. -->
    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style TargetType="{x:Type ui:NumberBox}" BasedOn="{StaticResource {x:Type ui:NumberBox}}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- NumberBox de año: tamaño y rango unificados para todos los campos de año.
         Ancho 150 para que el año de 4 dígitos + los spinners inline no queden truncados. -->
    <Style x:Key="YearNumberBox" TargetType="{x:Type ui:NumberBox}" BasedOn="{StaticResource {x:Type ui:NumberBox}}">
        <Setter Property="Minimum" Value="2000" />
        <Setter Property="Maximum" Value="2100" />
        <Setter Property="SpinButtonPlacementMode" Value="Inline" />
        <Setter Property="ClearButtonEnabled" Value="False" />
        <Setter Property="Width" Value="150" />
    </Style>

    <!-- Popup del Calendar (lo que se despliega al abrir el CalendarDatePicker): el brush default
         (CalendarViewBackground = ControlFillColorInputActive) tiene alpha y se ve transparente sobre Mica.
         Lo redefinimos como sólido tema-consciente, usando el mismo color que ContentDialog/MessageBox. -->
    <SolidColorBrush x:Key="CalendarViewBackground" Color="{DynamicResource SolidBackgroundFillColorBase}" />

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Botón de acento (equivalente a ui:Button Appearance="Primary" sobre un Button común).
         WPF-UI no define AccentButtonStyle como el Fluent nativo, así que lo replicamos
         usando sus brushes de acento. El acento usa el color de marca (ver App.AplicarAcentoMarca). -->
    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentButtonForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="11,5,11,6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ContentBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}">
                        <ContentPresenter x:Name="ContentPresenter"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource AccentButtonBackgroundPointerOver}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource AccentButtonBorderBrushPointerOver}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource AccentButtonBackgroundPressed}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource AccentButtonBorderBrushPressed}" />
                            <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource AccentButtonForegroundPressed}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource AccentButtonBackgroundDisabled}" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource AccentButtonBorderBrushDisabled}" />
                            <Setter TargetName="ContentPresenter" Property="TextElement.Foreground" Value="{DynamicResource AccentButtonForegroundDisabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón de acción primaria: usa el acento de marca -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <!-- Botón secundario: hereda el tema Fluent, normaliza padding -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <!-- Botón de acción con ícono (Wpf.Ui): ícono + texto en barras y formularios.
         El acento se setea por botón con Appearance="Primary" cuando corresponde. -->
    <Style x:Key="AccionIconButton" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Botón de acción compacto solo-ícono (Wpf.Ui): para columnas de acciones en grillas.
         Usar siempre con ToolTip describiendo la acción. -->
    <Style x:Key="AccionIconButtonCompact" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <!-- Botón borderless para toolbars (hover/pressed sutil, igual al proyecto de referencia) -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource ControlAltFillColorTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource ControlAltFillColorQuarternaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botones de chrome de ventana (minimize / maximize / close) -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#C42B1C" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#A3211A" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ui:Snackbar}" BasedOn="{StaticResource {x:Type ui:Snackbar}}">
        <Setter Property="MinWidth" Value="440" />
        <!--  El template interno tiene Padding="12" hardcodeado, así que controlamos el centrado
              con un ContentTemplate propio que centra el texto verticalmente.              -->
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock
                        Text="{Binding}"
                        VerticalAlignment="Center"
                        TextWrapping="WrapWithOverflow" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Deshabilita el DynamicScrollViewer de NavigationViewContentPresenter (WPF-UI v4.x).
         Por defecto IsDynamicScrollViewerEnabled=True usa el template con DynamicScrollViewer que
         envuelve las páginas midiendo el contenido con altura infinita. Esto rompe Grid rows Height="*":
         los ListBox/DataGrid reciben altura infinita y no scrollean internamente.
         El override del trigger para IsDynamicScrollViewerEnabled=True usa el template simple
         (DefaultNavigationViewContentPresenterControlTemplate) que no incluye DynamicScrollViewer,
         dando altura acotada a las páginas y permitiendo que * rows funcionen correctamente. -->
    <Style TargetType="{x:Type ui:NavigationViewContentPresenter}"
           BasedOn="{StaticResource {x:Type ui:NavigationViewContentPresenter}}">
        <Style.Triggers>
            <Trigger Property="IsDynamicScrollViewerEnabled" Value="True">
                <Setter Property="Template"
                        Value="{StaticResource DefaultNavigationViewContentPresenterControlTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

