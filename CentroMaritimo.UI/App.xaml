<Application x:Class="CentroMaritimo.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:CentroMaritimo.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:EstadoReciboToBrushConverter x:Key="EstadoReciboToBrushConverter" />
            <conv:EstadoReciboToFgBrushConverter x:Key="EstadoReciboToFgBrushConverter" />
            <conv:EstadoCierreToBrushConverter x:Key="EstadoCierreToBrushConverter" />
            <conv:EstadoCierreToFgBrushConverter x:Key="EstadoCierreToFgBrushConverter" />
            <conv:EstadoCierreToTextoConverter x:Key="EstadoCierreToTextoConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

