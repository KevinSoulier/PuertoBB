<UserControl x:Class="CentroMaritimo.UI.Controls.BusyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Panel.ZIndex="50"
             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
    <Grid>
        <!-- Fondo atenuado: más opaco que el smoke pelado anterior -->
        <Rectangle Fill="{DynamicResource SmokeFillColorDefaultBrush}" Opacity="0.6" />

        <!-- Tarjeta sólida y compacta (mismo lenguaje visual que los diálogos modales) -->
        <Border CornerRadius="8" MinWidth="300" MaxWidth="380" Padding="24"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Effect="{DynamicResource ElevationShadow16Effect}">
            <StackPanel>
                <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" HorizontalAlignment="Center" />

                <TextBlock Text="{Binding BusyTitulo}" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,12,0,0" />

                <TextBlock Text="{Binding BusyDetalle}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />

                <ProgressBar Minimum="0" Maximum="{Binding BusyTotal}" Value="{Binding BusyActual}"
                             Height="6" Margin="0,12,0,0"
                             Visibility="{Binding BusyMostrarProgreso, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock Text="{Binding BusyContador}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding BusyMostrarProgreso, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Content="Cancelar" Command="{Binding BusyCancelCommand}"
                        HorizontalAlignment="Center" Margin="0,16,0,0" MinWidth="90"
                        Visibility="{Binding BusyCancelable, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
