<Page x:Class="CentroMaritimo.UI.Views.GruposPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Grupos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Grupos de facturación" Style="{StaticResource PageTitle}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Grupos}" SelectedItem="{Binding Seleccionado}"
                     DisplayMemberPath="Nombre" Margin="0,0,16,0" />

            <Border Grid.Column="1" Padding="16" CornerRadius="8"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Datos del grupo" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Nombre" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NombreEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Descripción" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DescripcionEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Importe de cuota" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding ImporteEdit, UpdateSourceTrigger=PropertyChanged}" Width="140" HorizontalAlignment="Left" Margin="0,0,0,12" />
                    </StackPanel>

                    <!-- Buscador de miembros -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="Miembros" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding FiltroMiembros, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Buscar agencia…" />
                    </StackPanel>

                    <ListBox Grid.Row="3" ItemsSource="{Binding MiembrosFiltrados}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Nombre}" IsChecked="{Binding EsMiembro}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button Content="Nuevo" Command="{Binding NuevoCommand}"
                                   Style="{StaticResource AccionIconButton}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Guardar" Command="{Binding GuardarCommand}"
                                   Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="8,0,0,0">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                                   Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
