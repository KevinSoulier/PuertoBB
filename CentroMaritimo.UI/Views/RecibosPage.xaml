<Page x:Class="CentroMaritimo.UI.Views.RecibosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Recibos">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recibos" Style="{StaticResource PageTitle}" />

        <!-- Filtros período + acciones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding MesesNombres}" SelectedIndex="{Binding MesIndex}" Width="110" />
            <ui:NumberBox Value="{Binding Anio, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource YearNumberBox}" Margin="8,0,0,0" />
            <ui:TextBox PlaceholderText="Buscar en recibos..."
                        Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                        Width="200" Margin="8,0,0,0" VerticalAlignment="Center">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:TextBox.Icon>
            </ui:TextBox>
            <Separator Margin="4,0" />
            <ui:Button Content="Nuevo recibo" Command="{Binding AbrirEmisionIndividualCommand}"
                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0"
                       ToolTip="Emitir un recibo individual a una agencia específica.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="AddSquare24" /></ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Recibos}" SelectedItem="{Binding Seleccionado}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  SelectionMode="Single"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Agencia" Binding="{Binding Agencia}" Width="*" />
                <DataGridTextColumn Header="Comprobante" Binding="{Binding Comprobante}" Width="120" />
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="110" />
                <DataGridTextColumn Header="Emisión" Binding="{Binding FechaEmision}" Width="90" />
                <DataGridTemplateColumn Header="Estado" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Estado, Converter={StaticResource EstadoReciboToBrushConverter}}"
                                    CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" Margin="4,0">
                                <TextBlock Text="{Binding Estado}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding Estado, Converter={StaticResource EstadoReciboToFgBrushConverter}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Estado envío" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EstadoEnvio}" ToolTip="{Binding Error}"
                                       VerticalAlignment="Center" Margin="4,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Acciones" Width="230" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                <ui:Button IsEnabled="{Binding EsReintentable}"
                                           Style="{StaticResource AccionIconButtonCompact}"
                                           Click="Reintentar_Click"
                                           ToolTip="Emitir / reintentar emisión (obtener CAE)">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button IsEnabled="{Binding EsAnulable}"
                                           Style="{StaticResource AccionIconButtonCompact}" Margin="4,0,0,0"
                                           Click="Anular_Click"
                                           ToolTip="Anular emitiendo nota de crédito">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Prohibited24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button IsEnabled="{Binding EsReenviable}"
                                           Style="{StaticResource AccionIconButtonCompact}" Margin="4,0,0,0"
                                           Click="Reenviar_Click"
                                           ToolTip="Reenviar por correo">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Mail24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button IsEnabled="{Binding EsPagable}"
                                           Style="{StaticResource AccionIconButtonCompact}" Margin="4,0,0,0"
                                           Click="MarcarPagado_Click"
                                           ToolTip="Marcar como pagado">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="CheckmarkCircle24" /></ui:Button.Icon>
                                </ui:Button>
                                <ui:Button Style="{StaticResource AccionIconButtonCompact}" Margin="4,0,0,0"
                                           Click="Previsualizar_Click"
                                           ToolTip="Abrir PDF">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentPdf24" /></ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
