<Page x:Class="CentroMaritimo.UI.Views.VouchersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Vouchers">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Vouchers" Style="{StaticResource PageTitle}" />

        <!-- Barra de búsqueda: período con mes por nombre y año editable -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding MesesNombres}" SelectedIndex="{Binding MesIndex}" Width="110" />
            <ui:NumberBox Value="{Binding Anio, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource YearNumberBox}" Margin="8,0,0,0" />
            <ui:Button Content="Buscar" Command="{Binding BuscarCommand}"
                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="8,0,0,0">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Search24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Editar" Command="{Binding EditarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Previsualizar" Command="{Binding PrevisualizarVoucherCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                       ToolTip="Abre el PDF del voucher seleccionado en el visor embebido.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Eye24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Descargar" Command="{Binding DescargarVoucherCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="8,0,0,0"
                       ToolTip="Guarda el PDF del voucher seleccionado en disco.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <!-- Grilla con columna Emitido/Consolidado (VOU-8). Doble-click en la fila → editar -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Vouchers}" SelectedItem="{Binding Seleccionado}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" CanUserAddRows="False"
                  MouseDoubleClick="VouchersGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nro." Binding="{Binding Numero}" Width="80" />
                <DataGridTextColumn Header="Agencia" Binding="{Binding Agencia}" Width="*" />
                <DataGridTextColumn Header="Barco" Binding="{Binding Barco}" Width="*" />
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="100" />
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120" />
                <DataGridTextColumn Header="Estado" Binding="{Binding EstadoTexto}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Formulario nuevo / edición (VOU-2, VOU-3, VOU-7) -->
        <Border Grid.Row="4" Margin="0,16,0,0" Padding="16" CornerRadius="8"
                Background="{DynamicResource LayerFillColorDefaultBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding TextoBotonGuardar, StringFormat='{}  {0} voucher'}"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ui:Button Content="Cancelar" Command="{Binding CancelarEdicionCommand}"
                               Style="{StaticResource AccionIconButton}" Margin="12,0,0,0"
                               Visibility="{Binding ModoEdicion, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Altura uniforme de inputs (32px) provista por los estilos globales en Styles.xaml -->

                    <!-- Agencia autocomplete (VOU-3) -->
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="Agencia" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,2" />
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="AgenciaCombo"
                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                      ItemsSource="{Binding AgenciasFiltradas}"
                                      DisplayMemberPath="Nombre"
                                      Text="{Binding AgenciaTexto, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding AgenciaSeleccionada}"
                                      PreviewKeyDown="ComboBox_OpenOnDownKey"
                                      Width="200" />
                            <Button ToolTip="Ir a Agencias" Command="{Binding IrAAgenciasCommand}"
                                    Width="32" Height="32" Margin="4,0,0,0"
                                    Style="{StaticResource AccentButtonStyle}" Padding="2">
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Barco autocomplete con alta inline (VOU-2) -->
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Barco" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,2" />
                        <ComboBox x:Name="BarcoCombo"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                  ItemsSource="{Binding BarcosFiltrados}"
                                  DisplayMemberPath="Nombre"
                                  Text="{Binding BarcoTexto, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding BarcoSeleccionado}"
                                  PreviewKeyDown="ComboBox_OpenOnDownKey"
                                  Width="200" />
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Fecha" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,2" />
                        <DatePicker SelectedDate="{Binding FechaNueva}" Width="160" />
                    </StackPanel>

                    <!-- Importe (VOU-5: autopopulado) -->
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Importe" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ImporteNuevo, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                    </StackPanel>

                    <ui:Button Content="{Binding TextoBotonGuardar}" Command="{Binding CrearCommand}"
                               Style="{StaticResource AccionIconButton}" Appearance="Primary"
                               Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
                <TextBlock Text="* Barco nuevo: si el nombre no existe se crea automáticamente."
                           FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
