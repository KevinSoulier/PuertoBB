<Page x:Class="CentroMaritimo.UI.Views.VouchersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Vouchers">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Vouchers" Style="{StaticResource PageTitle}" />

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,8"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox ItemsSource="{Binding Meses}" SelectedItem="{Binding Mes}" Width="70" />
            <ComboBox ItemsSource="{Binding Anios}" SelectedItem="{Binding Anio}" Width="90" Margin="8,0,0,0" />
            <Button Content="Buscar" Command="{Binding BuscarCommand}"
                    Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
            <Button Content="Eliminar" Command="{Binding EliminarCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Vouchers}" SelectedItem="{Binding Seleccionado}"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nro." Binding="{Binding Numero}" Width="80" />
                <DataGridTextColumn Header="Agencia" Binding="{Binding Agencia}" Width="*" />
                <DataGridTextColumn Header="Barco" Binding="{Binding Barco}" Width="*" />
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="100" />
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Margin="0,16,0,0" Padding="16" CornerRadius="8"
                Background="{DynamicResource LayerFillColorDefaultBrush}">
            <StackPanel>
                <TextBlock Text="Nuevo voucher" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Agencias}" SelectedItem="{Binding AgenciaNueva}" DisplayMemberPath="Nombre" Width="200" />
                    <ComboBox ItemsSource="{Binding Barcos}" SelectedItem="{Binding BarcoNuevo}" DisplayMemberPath="Nombre" Width="180" Margin="8,0,0,0" />
                    <DatePicker SelectedDate="{Binding FechaNueva}" Width="130" Margin="8,0,0,0" />
                    <TextBox Text="{Binding ImporteNuevo, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="8,0,0,0" ToolTip="Importe" />
                    <Button Content="Crear" Command="{Binding CrearCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

