<Page x:Class="CentroMaritimo.UI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Inicio">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <TextBlock Text="Inicio" Style="{StaticResource PageTitle}" />

            <!-- Resumen rápido -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResumenVouchers}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Vouchers pendientes" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="4,0,4,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResumenRecibosVencidos}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                        <TextBlock Text="Recibos vencidos" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="8,0,0,0" Padding="20" CornerRadius="8"
                        Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResumenRecibosPendientes}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Recibos pendientes de pago" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Accesos rápidos -->
            <TextBlock Text="Accesos rápidos" FontWeight="SemiBold" FontSize="14"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <UniformGrid Columns="3" Margin="0,0,0,0">

                <Button Command="{Binding IrAVouchersCommand}" Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="TicketDiagonal24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Vouchers" FontWeight="SemiBold" />
                            <TextBlock Text="Cargar ingreso de buques" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAControlPagosCommand}" Margin="4,0,4,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="MoneyHand24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Control de pagos" FontWeight="SemiBold" />
                            <TextBlock Text="Recibos pendientes y vencidos" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAEmisionMasivaCommand}" Margin="8,0,0,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DocumentMultiple24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Emisión masiva" FontWeight="SemiBold" />
                            <TextBlock Text="Emitir recibos por grupo" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAAgenciasCommand}" Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="BuildingShop24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Agencias" FontWeight="SemiBold" />
                            <TextBlock Text="Gestión de agencias marítimas" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrABarcosCommand}" Margin="4,0,4,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="VehicleShip24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Barcos" FontWeight="SemiBold" />
                            <TextBlock Text="Listado de embarcaciones" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding IrAGruposCommand}" Margin="8,0,0,8"
                        Style="{StaticResource SecondaryButton}" Height="72" HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="24" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="Grupos" FontWeight="SemiBold" />
                            <TextBlock Text="Grupos de facturación" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
