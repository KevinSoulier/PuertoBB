<Page x:Class="CentroMaritimo.UI.Views.AgenciasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Agencias">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Agencias" Style="{StaticResource PageTitle}" />

        <!-- Buscador -->
        <ui:TextBox Grid.Row="2" Margin="0,0,0,12"
                 Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Buscar por nombre, razón social o CUIT…"
                 IsEnabled="{Binding NoEnEdicion}" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding AgenciasFiltradas}" SelectedItem="{Binding Seleccionada}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" CanUserAddRows="False" Margin="0,0,16,0"
                      SelectionMode="Single" IsEnabled="{Binding NoEnEdicion}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                    <DataGridTextColumn Header="Domicilio" Binding="{Binding Domicilio}" Width="2*" />
                    <DataGridTextColumn Header="CUIT" Binding="{Binding Cuit}" Width="130" />
                    <DataGridTextColumn Header="Mail" Binding="{Binding EmailsTexto}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Padding="16" CornerRadius="8"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Ficha de agencia" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel IsEnabled="{Binding EnEdicion}">
                        <TextBlock Text="Nombre" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NombreEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Razón social" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding RazonSocialEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="CUIT" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding CuitEdit, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Grid.Column="1" Content="Validar en ARCA" Command="{Binding ValidarCuitCommand}"
                                       Margin="8,0,0,0"
                                       ToolTip="Consulta la constancia de inscripción en ARCA y completa razón social, domicilio y condición IVA">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="CloudCheckmark24" /></ui:Button.Icon>
                            </ui:Button>
                        </Grid>
                        <TextBlock Text="Domicilio" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DomicilioEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Condición frente al IVA" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding CondicionesIva}"
                                  SelectedValue="{Binding CondicionIvaIdEdit, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Codigo" DisplayMemberPath="Display"
                                  Margin="0,0,0,8" />
                        <TextBlock Text="Emails (uno por línea)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EmailsEdit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                                 AcceptsReturn="True" Height="80" VerticalContentAlignment="Top"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,8">
                            <ui:Button Content="Nuevo" Command="{Binding NuevoCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Crear una nueva agencia">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Add24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Editar" Command="{Binding EditarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Editar la agencia seleccionada">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Edit24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Eliminar" Command="{Binding EliminarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Eliminar la agencia seleccionada">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                        <WrapPanel>
                            <ui:Button Content="Aceptar" Command="{Binding AceptarCommand}"
                                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0,0,8,8"
                                       ToolTip="Guardar los cambios de la agencia">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Save24" /></ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                                       ToolTip="Cancelar la edición">
                                <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                            </ui:Button>
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
