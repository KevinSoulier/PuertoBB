<Page x:Class="CentroMaritimo.UI.Views.CierrePeriodoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:CentroMaritimo.UI.Controls"
      xmlns:behaviors="clr-namespace:CentroMaritimo.UI.Behaviors"
      Title="Cierre de período">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Cierre de período (consolidación de vouchers)" Style="{StaticResource PageTitle}" />

        <!-- Barra de período + acciones globales -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,8,8" VerticalAlignment="Center">
                <TextBlock Text="Período:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding MesesNombres}" SelectedIndex="{Binding MesIndex}" Width="110" />
                <ui:NumberBox Value="{Binding Anio, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource YearNumberBox}" Margin="8,0,0,0" />
            </StackPanel>
            <ui:Button Content="Refrescar" Command="{Binding CargarCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Recargar las agencias con vouchers pendientes del período">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Emitir recibos" Command="{Binding EmitirRecibosCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Genera los recibos AFIP de todas las agencias pendientes SIN enviar mails.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentBulletList24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Enviar mails" Command="{Binding EnviarMailsCommand}"
                       Style="{StaticResource AccionIconButton}" Margin="0,0,8,8"
                       ToolTip="Envía el mail con el PDF consolidado de todos los recibos del período.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Mail24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cerrar período" Command="{Binding CerrarCommand}"
                       Style="{StaticResource AccionIconButton}" Appearance="Primary" Margin="0,0,8,8"
                       ToolTip="Genera recibos AFIP y envía mails a todas las agencias pendientes del período.">
                <ui:Button.Icon><ui:SymbolIcon Symbol="LockClosed24" /></ui:Button.Icon>
            </ui:Button>
        </WrapPanel>

        <!-- Resumen del período -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding Resumen}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,0,0">
                <Run Text="Total del período: " />
                <Run Text="{Binding TotalPeriodoTexto, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <!-- Grilla por agencia con sublista de vouchers y recibos -->
        <Grid Grid.Row="3">
            <DataGrid ItemsSource="{Binding Agencias}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      ScrollViewer.CanContentScroll="False"
                      RowHeight="40" MinColumnWidth="60">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Agencia" Binding="{Binding AgenciaNombre}" Width="*" />
                    <DataGridTextColumn Header="Vouchers" Binding="{Binding Vouchers.Count}" Width="80" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C2}" Width="120" />
                    <DataGridTextColumn Header="Recibos" Binding="{Binding Consolidados.Count}" Width="80" />
                    <DataGridTemplateColumn Header="Estado" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Estado, Converter={StaticResource EstadoCierreToBrushConverter}}"
                                        CornerRadius="10" Padding="10,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Estado, Converter={StaticResource EstadoCierreToTextoConverter}}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding Estado, Converter={StaticResource EstadoCierreToFgBrushConverter}}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Acciones (vouchers libres)" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <WrapPanel VerticalAlignment="Center">
                                    <ui:Button Command="{Binding DataContext.PrevisualizarLibresCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource AccionIconButtonCompact}" Margin="0,0,6,6"
                                               ToolTip="Previsualizar PDF de los vouchers libres">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentPdf24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.DescargarLibresCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource AccionIconButtonCompact}" Margin="0,0,6,6"
                                               ToolTip="Descargar PDF de los vouchers libres">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Command="{Binding DataContext.EmitirReciboAgenciaCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource AccionIconButtonCompact}" Appearance="Primary" Margin="0,0,6,6"
                                               ToolTip="Generar recibo en AFIP por los vouchers libres (complementario si ya hay uno)">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentBulletList24" /></ui:Button.Icon>
                                    </ui:Button>
                                </WrapPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Margin="32,6,4,10" Padding="16,12"
                                HorizontalAlignment="Left"
                                MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                Background="{DynamicResource LayerFillColorDefaultBrush}"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Vouchers del período" FontWeight="SemiBold" FontSize="12"
                                           Margin="0,0,0,10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <DataGrid ItemsSource="{Binding Vouchers}" AutoGenerateColumns="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal" CanUserAddRows="False"
                                          Background="Transparent"
                                          RowHeight="36"
                                          MinColumnWidth="60"
                                          HorizontalScrollBarVisibility="Disabled"
                                          behaviors:MouseWheel.BubbleToParent="True"
                                          SelectionMode="Single">
                                    <DataGrid.Resources>
                                        <Style x:Key="CeldaVoucher" TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8,0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nro." Binding="{Binding Numero}" Width="80"
                                                            ElementStyle="{StaticResource CeldaVoucher}" />
                                        <DataGridTextColumn Header="Barco" Binding="{Binding Barco}" Width="*"
                                                            ElementStyle="{StaticResource CeldaVoucher}" />
                                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" Width="110"
                                                            ElementStyle="{StaticResource CeldaVoucher}" />
                                        <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=C2}" Width="130"
                                                            ElementStyle="{StaticResource CeldaVoucher}" />
                                        <DataGridTextColumn Header="Comprobante" Binding="{Binding ComprobanteTexto}" Width="120"
                                                            ElementStyle="{StaticResource CeldaVoucher}" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Recibos consolidados emitidos (original + complementarios) -->
                                <StackPanel Margin="0,16,0,0"
                                            Visibility="{Binding TieneConsolidados, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Recibos emitidos" FontWeight="SemiBold" FontSize="12"
                                               Margin="0,0,0,10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <DataGrid ItemsSource="{Binding Consolidados}" AutoGenerateColumns="False"
                                              IsReadOnly="True" HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal" CanUserAddRows="False"
                                              Background="Transparent"
                                              RowHeight="40"
                                              MinColumnWidth="60"
                                              HorizontalScrollBarVisibility="Disabled"
                                              behaviors:MouseWheel.BubbleToParent="True"
                                              SelectionMode="Single">
                                        <DataGrid.Resources>
                                            <Style x:Key="CeldaRecibo" TargetType="TextBlock">
                                                <Setter Property="Margin" Value="8,0" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nro. comp." Binding="{Binding NumeroComprobante}" Width="110"
                                                                ElementStyle="{StaticResource CeldaRecibo}" />
                                            <DataGridTextColumn Header="Vouchers" Binding="{Binding CantVouchers}" Width="90"
                                                                ElementStyle="{StaticResource CeldaRecibo}" />
                                            <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=C2}" Width="130"
                                                                ElementStyle="{StaticResource CeldaRecibo}" />
                                            <DataGridTemplateColumn Header="Estado" Width="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Estado, Converter={StaticResource EstadoCierreToBrushConverter}}"
                                                                CornerRadius="10" Padding="10,3" HorizontalAlignment="Left"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Estado, Converter={StaticResource EstadoCierreToTextoConverter}}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{Binding Estado, Converter={StaticResource EstadoCierreToFgBrushConverter}}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Acciones" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <WrapPanel VerticalAlignment="Center">
                                                            <ui:Button Command="{Binding DataContext.PrevisualizarReciboCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}"
                                                                       Style="{StaticResource AccionIconButtonCompact}" Margin="0,0,6,0"
                                                                       ToolTip="Previsualizar PDF del recibo">
                                                                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentPdf24" /></ui:Button.Icon>
                                                            </ui:Button>
                                                            <ui:Button Command="{Binding DataContext.DescargarReciboCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}"
                                                                       Style="{StaticResource AccionIconButtonCompact}" Margin="0,0,6,0"
                                                                       ToolTip="Descargar PDF del recibo">
                                                                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                                                            </ui:Button>
                                                            <ui:Button Command="{Binding DataContext.EnviarMailReciboCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}"
                                                                       Style="{StaticResource AccionIconButtonCompact}" Margin="0,0,6,0"
                                                                       ToolTip="Enviar mail con el PDF del recibo">
                                                                <ui:Button.Icon><ui:SymbolIcon Symbol="Mail24" /></ui:Button.Icon>
                                                            </ui:Button>
                                                        </WrapPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </Grid>

        <controls:BusyOverlay Grid.RowSpan="4" />
    </Grid>
</Page>
